services:
#/* ---------------------------- Traefik --------------------------- */
  traefik:
    image: {{ vault_traefik_image | to_json }}
    container_name: traefik
    restart: unless-stopped
    command:
      - "--api.dashboard=true"
      - "--api.insecure=false"
      - "--providers.docker=true"
      - "--providers.docker.exposedbydefault=false"
      - "--providers.docker.network=portfolio"
      - "--entrypoints.web.address=:80"
      - "--entrypoints.websecure.address=:443"
      - "--entrypoints.web.http.redirections.entryPoint.to=websecure"
      - "--entrypoints.web.http.redirections.entryPoint.scheme=https"
      - "--certificatesresolvers.letsencrypt.acme.email={{ vault_acme_email }}"
      - "--certificatesresolvers.letsencrypt.acme.storage=/acme.json"
      - "--certificatesresolvers.letsencrypt.acme.httpchallenge.entrypoint=web"
      - "--metrics.prometheus=true"
      - "--metrics.prometheus.entryPoint=metrics"
      - "--entrypoints.metrics.address=:8082"
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ./acme.json:/acme.json
    networks:
      - portfolio
      - ipseis
      - jenkins
#/* ---------------------------- Jenkins --------------------------- */
  jenkins-dind:
    image: {{ vault_jenkins_dind_image }}
    container_name: jenkins-dind
    profiles:
      - jenkins
    command: --storage-driver overlay2
    privileged: true
    environment:
      - DOCKER_TLS_CERTDIR=/certs
    volumes:
      - jenkins-docker-certs:/certs/client
      - jenkins-data:/var/jenkins_home
    networks:
      jenkins:
        aliases:
          - docker

  jenkins-gui:
    image: {{ vault_jenkins_image }}
    container_name: jenkins-gui
    profiles:
      - jenkins
    pull_policy: always
    restart: on-failure
    depends_on:
      - jenkins-dind
    environment:
      DOCKER_HOST: {{ vault_jenkins_docker_host }}
      DOCKER_CERT_PATH: /certs/client
      DOCKER_TLS_VERIFY: 1
      JENKINS_OPTS: --httpPort={{ vault_jenkins_port }}
      JENKINS_URL: "https://{{ vault_jenkins_subdomain }}.{{ vault_base_domain }}/"
      JAVA_OPTS: -Djenkins.model.Jenkins.crumbIssuerProxyCompatibility=true -Dhudson.security.csrf.DefaultCrumbIssuer.EXCLUDE_SESSION_ID=true
    labels:
      - traefik.enable=true
      - traefik.http.routers.jenkins.rule=Host(`{{ vault_jenkins_subdomain }}.{{ vault_base_domain }}`)
      - traefik.http.routers.jenkins.entrypoints=websecure
      - traefik.http.routers.jenkins.tls.certresolver=letsencrypt
      - traefik.http.services.jenkins.loadbalancer.server.port={{ vault_jenkins_port }}
      - traefik.http.routers.jenkins.middlewares=jenkins-headers
      - traefik.http.middlewares.jenkins-headers.headers.customrequestheaders.X-Forwarded-Proto=https
      - traefik.http.middlewares.jenkins-headers.headers.customrequestheaders.X-Forwarded-Port=443
    volumes:
      - jenkins-data:/var/jenkins_home
      - jenkins-docker-certs:/certs/client:ro
    networks:
      - jenkins
#/* ------------------------ Cluster MongoDB ----------------------- */
{% for env in vault_mongodb_environments %}
  {{ env.name }}:
    image: {{ vault_mongodb_image | to_json }}
    container_name: {{ env.name }}
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "mongosh", "--quiet", "--eval", "db.runCommand('ping').ok"]
    environment:
      MONGO_INITDB_ROOT_USERNAME: {{ vault_mongodb_root_user | to_json }}
      MONGO_INITDB_ROOT_PASSWORD: {{ env.root_password | to_json }}
    command: --wiredTigerCacheSizeGB 1
    ports:
      - "127.0.0.1:{{ env.port }}:27017"
    volumes:
      - {{ env.name }}-data:/data/db
    networks:
      - ipseis
{% endfor %}
#/* --------------------------- Portfolio -------------------------- */
  portfolio-frontend:
    image: {{ vault_portfolio_image }}
    container_name: portfolio-frontend
    restart: on-failure
    labels:
      - traefik.enable=true
      - traefik.http.routers.portfolio_frontend.rule=Host(`{{ vault_base_domain }}`) || Host(`{{ vault_base_domain_fr }}`)
      - traefik.http.routers.portfolio_frontend.entrypoints=websecure
      - traefik.http.routers.portfolio_frontend.tls.certresolver=letsencrypt
      - traefik.http.services.portfolio_frontend.loadbalancer.server.port=3000
    networks:
      - portfolio
#/* --------------------------- Ipseis API ------------------------- */
{% for env in vault_ipseis_environments %}
  {{ env.name }}:
    image: {{ env.image | to_json }}
    container_name: {{ env.name }}
    restart: on-failure
    depends_on:
      {{ env.mongodb_host }}:
        condition: service_healthy
    environment:
      USER_AGENT_ENV: {{ env.profile | to_json }}
      MONGODB_URI: "mongodb://{{ vault_ipseis_backend_username }}:{{ env.mongodb_password }}@{{ env.mongodb_host }}:27017/{{ env.mongodb_database }}?authSource=admin"
      FRONTEND_URL: {{ env.frontend_url | to_json }}
      JWT_SECRET: {{ vault_ipseis_jwt_secret | to_json }}
      NODEMAILER_EMAIL: {{ vault_nodemailer_email | to_json }}
      NODEMAILER_EMAIL_TO: {{ env.nodemailer_email_to | to_json }}
      NODEMAILER_PASSWORD: {{ vault_nodemailer_password | to_json }}
      BACKEND_USERNAME: {{ vault_ipseis_backend_username | to_json }}
      BACKEND_PASSWORD: {{ vault_ipseis_backend_password | to_json }}
    labels:
      traefik.enable: "true"
      traefik.http.routers.ipseis_api_{{ env.profile }}.entrypoints: websecure
      traefik.http.routers.ipseis_api_{{ env.profile }}.tls.certresolver: letsencrypt
      traefik.http.services.ipseis_api_{{ env.profile }}.loadbalancer.server.port: "3000"
      traefik.http.routers.ipseis_api_{{ env.profile }}.rule: Host(`{{ env.subdomain }}.{{ vault_base_domain_fr }}`)
    volumes:
      - {{ env.name }}-data:/app/public/uploads
    networks:
      - ipseis
{% endfor %}

volumes:
# Jenkins
  jenkins-data:
  jenkins-docker-certs:
# Cluster MongoDB
{% for env in vault_mongodb_environments %}
  {{ env.name }}-data:
{% endfor %}
# Ipseis API
{% for env in vault_ipseis_environments %}
  {{ env.name }}-data:
{% endfor %}

networks:
  portfolio:
    name: portfolio
  jenkins:
    name: jenkins
  ipseis:
    name: ipseis