---
services:
  mongo-test:
    image: {{ ipseis_db_image }}
    container_name: mongo-test
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 1G
          cpus: 1.5
        reservations:
          memory: 256M
          cpus: 0.25
    healthcheck:
      test:
        - CMD
        - mongosh
        - --quiet
        - --username
        - "{{ mongo_test_db_root_user }}"
        - --password
        - "{{ mongo_test_db_root_password }}"
        - --authenticationDatabase
        - admin
        - --eval
        - "db.runCommand('ping').ok"
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    command: --wiredTigerCacheSizeGB 1
    environment:
      - MONGO_INITDB_ROOT_USERNAME={{ mongo_test_db_root_user }}
      - MONGO_INITDB_ROOT_PASSWORD={{ mongo_test_db_root_password }}
    volumes:
      - mongo-test:/data/db
    ports:
      - "127.0.0.1:{{ mongo_test_db_external_port }}:27017"
    networks:
      - mongo-test-internal

volumes:
  mongo-test:
    name: mongo-test

networks:
  mongo-test-internal:
    name: mongo-test-internal
    driver: bridge